{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GrammarPipeline": {
    "TreebankPath": "quranic-treebank-repo/corpus/Quranic.csv",
    "DownloadUrls": [
      "https://github.com/NoorBayan/Quranic/raw/main/corpus/Quranic.rar",
      "https://github.com/NoorBayan/Quranic/raw/master/corpus/Quranic.rar"
    ]
  },
  "ContextClassifier": {
    "TrainingTimeoutMinutes": 30,
    "MinUniqueRoots": 7,
    "F1ConvergenceDelta": 0.001,
    "EarlyStoppingPatience": 3,
    "ModelOutputDirectory": "models/context"
  }
}