@page "/"

<PageTitle>LisanBits - Data Crawler Dashboard</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-diagram-3-fill text-primary"></i> LisanBits Data Constitution Dashboard <span class="badge bg-success" style="font-size: 0.4em;">Live</span></h1>
        <button class="btn btn-danger" @onclick="ResetDatabase"><i class="bi bi-exclamation-triangle-fill"></i> HARD RESET DATABASE</button>
    </div>
    
    <!-- Stats Section -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white"><i class="bi bi-pie-chart-fill"></i> Data Constitution (Category Balance)</div>
                <div class="card-body">
                    @if (categoryStats == null)
                    {
                        <p>Loading stats...</p>
                    }
                    else if (!categoryStats.Any())
                    {
                        <p class="text-muted">No data scraped yet. Waiting for worker...</p>
                    }
                    else
                    {
                        var totalSentences = categoryStats.Sum(c => c.TotalSentences);
                        totalSentences = totalSentences == 0 ? 1 : totalSentences;

                        foreach (var cat in categoryStats.OrderByDescending(c => c.TotalSentences))
                        {
                            double percent = (double)cat.TotalSentences / totalSentences * 100;
                            string barClass = percent > 30 ? "bg-warning" : "bg-success";
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong>@cat.Category</strong>
                                    <span>@cat.TotalSentences Sentences (@percent.ToString("0.0")%)</span>
                                </div>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar @barClass" role="progressbar" style="width: @percent%;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted">@cat.TotalWords Words</small>
                            </div>
                        }
                    }
                </div>
                <!-- Duplicate Detection Footer -->
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @if (isScanningDuplicates)
                            {
                                <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                <span class="ms-2 text-primary">Scanning for duplicates (takes ~6s)...</span>
                            }
                            else if (totalDuplicates.HasValue)
                            {
                                if (totalDuplicates.Value > 0)
                                {
                                    <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Found @totalDuplicates.Value.ToString("N0") duplicates</span>
                                }
                                else
                                {
                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i> No duplicates found</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted"><i class="bi bi-info-circle"></i> Duplicate scan pending</span>
                            }
                        </div>
                        <div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ScanForDuplicates" 
                                disabled="@(isRemovingDuplicates || isScanningDuplicates)"
                            ><i class="bi bi-search"></i> Scan</button>
                            @if (totalDuplicates.HasValue && totalDuplicates.Value > 0)
                            {
                                <button class="btn btn-danger btn-sm ms-2" @onclick="RemoveDuplicates" disabled="@(isRemovingDuplicates || isScanningDuplicates)">
                                    @if(isRemovingDuplicates || isScanningDuplicates) { <span class="spinner-border spinner-border-sm"></span> }
                                    else { <i class="bi bi-trash"></i> } Remove
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white"><i class="bi bi-bar-chart-fill"></i> Extraction by Source</div>
                <div class="card-body">
                    @if (sourceStats != null && sourceStats.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var src in sourceStats.OrderByDescending(s => s.TotalSentences))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @src.Source
                                    <span class="badge bg-primary rounded-pill">@src.TotalSentences</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                         <p class="text-muted">No source data yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== PIPELINE EXECUTION FLOW ==================== -->
    <div class="card shadow-sm mb-4 pipeline-map-card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span><i class="bi bi-shuffle"></i> Pipeline Execution Order & Progress</span>
            <span class="badge bg-secondary">Epics 1 - 4</span>
        </div>
        <div class="card-body bg-black bg-opacity-20 py-4">
            <div class="row text-center align-items-center position-relative">
                
                <!-- Step 1 Node -->
                <div class="col-md-3 col-sm-6 position-relative mb-4 mb-md-0" style="z-index: 2;">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle border border-2 step-circle @(GetStepBorderClass(1))" style="width: 60px; height: 60px; background-color: #0b0e14; position: relative;">
                        @{ var s1 = GetStepStatusLabel(1); }
                        @if (s1 == "Running") { <i class="bi bi-arrow-repeat spin fs-4 text-primary"></i> }
                        else if (s1 == "Completed") { <i class="bi bi-check-lg fs-4 text-success"></i> }
                        else if (s1 == "Pending Data") { <i class="bi bi-hourglass-split fs-4 text-warning"></i> }
                        else { <span class="fs-4 text-white">1</span> }
                    </div>
                    <div class="mt-2">
                        <div class="fw-bold @(GetStepTextClass(1))">Step 1</div>
                        <div class="text-white-50 small">Raw Ingestion</div>
                        <span class="badge @(GetStepBadgeClass(1)) mt-1">@s1</span>
                    </div>
                </div>

                <!-- Connector 1-2 -->
                <div class="d-none d-md-block position-absolute connector-line" style="left: 12.5%; width: 25%; top: 30px; height: 3px; background: @(GetConnectorGradient(1, 2)); z-index: 0;"></div>

                <!-- Step 2 Node -->
                <div class="col-md-3 col-sm-6 position-relative mb-4 mb-md-0" style="z-index: 2;">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle border border-2 step-circle @(GetStepBorderClass(2))" style="width: 60px; height: 60px; background-color: #0b0e14; position: relative;">
                        @{ var s2 = GetStepStatusLabel(2); }
                        @if (s2 == "Blocked") { <i class="bi bi-lock-fill fs-4 text-muted"></i> }
                        else if (s2 == "Running") { <i class="bi bi-arrow-repeat spin fs-4 text-primary"></i> }
                        else if (s2 == "Completed") { <i class="bi bi-check-lg fs-4 text-success"></i> }
                        else if (s2 == "Failed") { <i class="bi bi-exclamation-triangle-fill fs-4 text-danger"></i> }
                        else { <span class="fs-4 text-white">2</span> }
                    </div>
                    <div class="mt-2">
                        <div class="fw-bold @(GetStepTextClass(2))">Step 2</div>
                        <div class="text-white-50 small">Lexicon Seeding</div>
                        <span class="badge @(GetStepBadgeClass(2)) mt-1">@s2</span>
                    </div>
                </div>

                <!-- Connector 2-3 -->
                <div class="d-none d-md-block position-absolute connector-line" style="left: 37.5%; width: 25%; top: 30px; height: 3px; background: @(GetConnectorGradient(2, 3)); z-index: 0;"></div>

                <!-- Step 3 Node -->
                <div class="col-md-3 col-sm-6 position-relative mb-4 mb-sm-0" style="z-index: 2;">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle border border-2 step-circle @(GetStepBorderClass(3))" style="width: 60px; height: 60px; background-color: #0b0e14; position: relative;">
                        @{ var s3 = GetStepStatusLabel(3); }
                        @if (s3 == "Blocked") { <i class="bi bi-lock-fill fs-4 text-muted"></i> }
                        else if (s3 == "Running") { <i class="bi bi-arrow-repeat spin fs-4 text-primary"></i> }
                        else if (s3 == "Completed") { <i class="bi bi-check-lg fs-4 text-success"></i> }
                        else if (s3 == "Failed") { <i class="bi bi-exclamation-triangle-fill fs-4 text-danger"></i> }
                        else { <span class="fs-4 text-white">3</span> }
                    </div>
                    <div class="mt-2">
                        <div class="fw-bold @(GetStepTextClass(3))">Step 3</div>
                        <div class="text-white-50 small">ConceptNet Seeding</div>
                        <span class="badge @(GetStepBadgeClass(3)) mt-1">@s3</span>
                    </div>
                </div>

                <!-- Connector 2-4 -->
                <div class="d-none d-md-block position-absolute connector-line" style="left: 62.5%; width: 25%; top: 30px; height: 3px; background: @(GetConnectorGradient(2, 4)); z-index: 0;"></div>

                <!-- Step 4 Node -->
                <div class="col-md-3 col-sm-6 position-relative" style="z-index: 2;">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle border border-2 step-circle @(GetStepBorderClass(4))" style="width: 60px; height: 60px; background-color: #0b0e14; position: relative;">
                        @{ var s4 = GetStepStatusLabel(4); }
                        @if (s4 == "Blocked") { <i class="bi bi-lock-fill fs-4 text-muted"></i> }
                        else if (s4 == "Running") { <i class="bi bi-arrow-repeat spin fs-4 text-primary"></i> }
                        else if (s4 == "Completed") { <i class="bi bi-check-lg fs-4 text-success"></i> }
                        else if (s4 == "Failed") { <i class="bi bi-exclamation-triangle-fill fs-4 text-danger"></i> }
                        else { <span class="fs-4 text-white">4</span> }
                    </div>
                    <div class="mt-2">
                        <div class="fw-bold @(GetStepTextClass(4))">Step 4</div>
                        <div class="text-white-50 small">Grammar Training</div>
                        <span class="badge @(GetStepBadgeClass(4)) mt-1">@s4</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ==================== STEP 1: RAW DATA INGESTION ==================== -->
    <div class="border border-primary rounded p-4 mb-4 bg-light bg-opacity-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="text-primary mb-0"><span class="badge bg-primary me-2">Step 1</span> Raw Data Ingestion (Crawling & Extraction)</h3>
            <span class="badge bg-success"><i class="bi bi-patch-check"></i> Root Pipeline Step</span>
        </div>
        <p class="text-muted small">
            <strong>What this action does:</strong> Automatically runs the data scraper worker to crawl web sources or parse local books.
            It cleans the text by filtering out non-Arabic text using <strong>FastText Language Identification</strong> (threshold > 0.9)
            and filters out near-duplicates using <strong>MinHash deduplication</strong> (Jaccard similarity >= 0.85) before staging them in SQLite.
        </p>
        <p class="text-muted small">
            <strong>Dependencies & Blockers:</strong> None. This is the root step of the pipeline. It populates the staging SQLite tables which all subsequent graph-seeding and syntax training steps depend upon.
        </p>

        <!-- Active Scraper Jobs Panel -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white"><i class="bi bi-cpu-fill"></i> Active Scraper Jobs</div>
            <div class="card-body">
                @if (scrapeJobs == null)
                {
                    <p><em>Loading scraping jobs...</em></p>
                }
                else if (!scrapeJobs.Any())
                {
                    <div class="alert alert-info mb-0">No active scraping jobs found. The worker might be idle.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Source</th>
                                    <th>Category</th>
                                    <th>Target URL / ID</th>
                                    <th>Pages Processed</th>
                                    <th>Status</th>
                                    <th>Last Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var job in scrapeJobs)
                                {
                                    <tr>
                                        <td><strong>@job.SourceName</strong></td>
                                        <td><span class="badge bg-secondary">Universal</span></td>
                                        <td>@job.TargetId</td>
                                        <td><span class="badge bg-primary rounded-pill">@job.LastProcessedIndex</span></td>
                                        <td>
                                            @if (job.Status == "InProgress")
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> In Progress</span>
                                            }
                                            else if (job.Status == "Completed")
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Completed</span>
                                            }
                                            else if (job.Status == "Idle")
                                            {
                                                <span class="badge bg-secondary"><i class="bi bi-pause-circle"></i> Idle (Queue Empty)</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@job.Status</span>
                                            }
                                        </td>
                                        <td>@job.LastUpdatedAt.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Configured Data Sources Panel -->
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><i class="bi bi-gear-fill"></i> Configured Data Sources</div>
            <div class="card-body">
                @if (configs == null)
                {
                    <p>Loading configurations...</p>
                }
                else
                {
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Category</th>
                                    <th>Base URL</th>
                                    <th>Target XPath</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cfg in configs)
                                {
                                    <tr>
                                        <td>@cfg.Id</td>
                                        <td>@cfg.Name</td>
                                        <td><span class="badge bg-info text-dark">@cfg.Category</span></td>
                                        <td><small>@cfg.BaseUrl</small></td>
                                        <td><code>@cfg.TargetXPath</code></td>
                                        <td>
                                            @if(cfg.IsActive) { <span class="badge bg-success mb-1">Active</span> } else { <span class="badge bg-danger mb-1">Disabled</span> }
                                            <button class="btn btn-sm btn-outline-danger d-block w-100 mt-1" @onclick="() => ResetSource(cfg.Name)" title="Reset this source's data">Reset Data</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <h5>Add New Source</h5>
                    <div class="row g-3 align-items-center">
                        <div class="col-md-2"><input type="text" class="form-control" placeholder="Name (e.g. Al Arabiya)" @bind="newConfig.Name" /></div>
                        <div class="col-md-2">
                            <input type="text" class="form-control" list="categoryOptions" placeholder="Category" @bind="newConfig.Category" />
                            <datalist id="categoryOptions">
                                <option value="News"></option>
                                <option value="Science"></option>
                                <option value="Medical"></option>
                                <option value="Finance"></option>
                                <option value="Literature"></option>
                                <option value="Sports"></option>
                                <option value="Slang"></option>
                                <option value="Religion"></option>
                                <option value="DailyLife"></option>
                            </datalist>
                        </div>
                        <div class="col-md-3"><input type="text" class="form-control" placeholder="Base URL" @bind="newConfig.BaseUrl" /></div>
                        <div class="col-md-2"><input type="text" class="form-control" placeholder="XPath (e.g. //div)" @bind="newConfig.TargetXPath" /></div>
                        <div class="col-md-2"><input type="text" class="form-control" placeholder="Pagination (e.g. ?p=)" @bind="newConfig.PaginationParam" /></div>
                        <div class="col-md-1">
                            <button class="btn btn-primary w-100" @onclick="AddSource"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ==================== STEP 2: LEXICON GRAPH SEEDING ==================== -->
    <div class="border border-secondary rounded p-4 mb-4 bg-light bg-opacity-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="text-secondary mb-0"><span class="badge bg-secondary me-2">Step 2</span> Lexicon Graph Seeding (Dictionary Seeding)</h3>
            @{
                var step2Status = GetStepStatusLabel(2);
                string badgeClass2 = step2Status == "Completed" ? "bg-success" : step2Status == "Running" ? "bg-primary" : step2Status == "Blocked" ? "bg-secondary" : "bg-info";
            }
            <span class="badge @badgeClass2">@step2Status</span>
        </div>
        <p class="text-muted small">
            <strong>What this action will do:</strong> Migrates the standard Arabic dictionaries (e.g. Shamela) and dialect books (e.g. Taimoor) from the SQLite staging database into the Neo4j Graph Database. It constructs root nodes (<code>Root</code>), vocabulary word nodes (<code>Word</code>), dialect etymological nodes (<code>DialectWord</code>), and registers their structural relationships (such as <code>HAS_ROOT</code>, <code>SHARES_ROOT</code>, and <code>DIALECT_MAPS_TO</code>).
        </p>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><i class="bi bi-share-fill"></i> Lexicon Graph Database Seeding</div>
            <div class="card-body">
                @if (seederStatus == null)
                {
                    <div class="d-flex align-items-center text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                        <span>Loading Graph Seeder status...</span>
                    </div>
                }
                else
                {
                    <div class="row align-items-center">
                        <div class="col-md-3 mb-3 mb-md-0">
                            <div class="p-3 border rounded text-center">
                                <span class="text-muted d-block small mb-1">Seeder Status</span>
                                @if (seederStatus.Status == "Idle")
                                {
                                    <span class="badge bg-secondary fs-6"><i class="bi bi-info-circle"></i> Idle</span>
                                }
                                else if (seederStatus.Status == "Seeding")
                                {
                                    <span class="badge bg-primary fs-6"><i class="bi bi-arrow-repeat spin"></i> Seeding</span>
                                }
                                else if (seederStatus.Status == "Completed")
                                {
                                    <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Completed</span>
                                }
                                else if (seederStatus.Status == "Failed")
                                {
                                    <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle"></i> Failed</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3 mb-md-0">
                            @if (!IsStep1Completed())
                            {
                                <div class="alert alert-warning py-2 mb-0 small">
                                    <h6 class="alert-heading fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill"></i> Step 2 Blocked: Waiting for Step 1 (Raw Ingestion)</h6>
                                    @if (IsStep1Running())
                                    {
                                        <span><strong>Reason:</strong> Step 1 Crawlers/Scrapers are actively running (InProgress). We must wait for ingestion to complete before migrating static dictionaries.</span>
                                    }
                                    else if (lexiconCount == 0)
                                    {
                                        <span><strong>Reason:</strong> No lexicon entries exist in the SQLite staging database. We cannot seed roots and words into Neo4j if SQLite is empty.</span>
                                    }
                                </div>
                            }
                            else if (seederStatus.Status == "Seeding")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Seeding lexicon to Neo4j (@(seederStatus.Progress.ToString("0.0"))%)</span>
                                    <span>@(seederStatus.ProcessedCount.ToString("N0")) / @(seederStatus.TotalEntries.ToString("N0"))</span>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(seederStatus.Progress)%;" aria-valuenow="@(seederStatus.Progress)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                            else if (seederStatus.Status == "Completed")
                            {
                                <div class="alert alert-success py-2 mb-0"><i class="bi bi-check-circle-fill"></i> Lexicon seeding completed successfully. Total processed entries: <strong>@(seederStatus.ProcessedCount.ToString("N0"))</strong></div>
                            }
                            else if (seederStatus.Status == "Failed")
                            {
                                <div class="alert alert-danger py-2 mb-0"><i class="bi bi-exclamation-octagon-fill"></i> Seeding failed: @(seederStatus.ErrorMessage)</div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Lexicon Graph database is currently idle. Click trigger to begin seeding.</p>
                            }
                        </div>
                        <div class="col-md-3 text-end">
                            @if (!IsStep1Completed())
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-lock-fill"></i> Blocked (No Lexicon)</button>
                            }
                            else if (seederStatus.Status == "Idle" || seederStatus.Status == "Completed" || seederStatus.Status == "Failed")
                            {
                                <button class="btn btn-primary w-100 mb-2" @onclick="TriggerSeeding"><i class="bi bi-play-fill"></i> Trigger Seeding</button>
                                <button class="btn btn-outline-danger w-100" @onclick="ResetGraph"><i class="bi bi-trash-fill"></i> Reset Lexicon Graph</button>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-hourglass-split"></i> Seeding...</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ==================== STEP 3: SEMANTIC EDGE SEEDING ==================== -->
    <div class="border border-info rounded p-4 mb-4 bg-light bg-opacity-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="text-info mb-0"><span class="badge bg-info text-dark me-2">Step 3</span> Semantic Edge Seeding (ConceptNet Semantic Mapping)</h3>
            @{
                var step3Status = GetStepStatusLabel(3);
                string badgeClass3 = step3Status == "Completed" ? "bg-success" : step3Status == "Running" ? "bg-primary" : step3Status == "Blocked" ? "bg-secondary" : "bg-info";
            }
            <span class="badge @badgeClass3">@step3Status</span>
        </div>
        <p class="text-muted small">
            <strong>What this action will do:</strong> Downloads global ConceptNet assertions, parses the dataset, isolates Arabic language semantic assertions (such as translations, synonyms, antonyms, etc.), and merges these semantic edges directly onto the seeded Neo4j word nodes. This creates connections like <code>SYNONYM_OF</code> and <code>ANTONYM_OF</code> between existing words.
        </p>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><i class="bi bi-share-fill"></i> ConceptNet Graph Knowledge Seeding</div>
            <div class="card-body">
                @if (importerStatus == null)
                {
                    <div class="d-flex align-items-center text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                        <span>Loading ConceptNet Importer status...</span>
                    </div>
                }
                else
                {
                    <div class="row align-items-center">
                        <div class="col-md-3 mb-3 mb-md-0">
                            <div class="p-3 border rounded text-center">
                                <span class="text-muted d-block small mb-1">Importer Status</span>
                                @if (importerStatus.Status == "Idle")
                                {
                                    <span class="badge bg-secondary fs-6"><i class="bi bi-info-circle"></i> Idle</span>
                                }
                                else if (importerStatus.Status == "Downloading")
                                {
                                    <span class="badge bg-warning text-dark fs-6"><i class="bi bi-download"></i> Downloading</span>
                                }
                                else if (importerStatus.Status == "Importing")
                                {
                                    <span class="badge bg-primary fs-6"><i class="bi bi-arrow-repeat spin"></i> Importing</span>
                                }
                                else if (importerStatus.Status == "Completed")
                                {
                                    <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Completed</span>
                                }
                                else if (importerStatus.Status == "Failed")
                                {
                                    <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle"></i> Failed</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3 mb-md-0">
                            @if (seederStatus == null || seederStatus.Status != "Completed")
                            {
                                <div class="alert alert-warning py-2 mb-0 small">
                                    <h6 class="alert-heading fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill"></i> Step 3 Blocked: Waiting for Step 2 (Lexicon Graph Seeding)</h6>
                                    <span><strong>Reason:</strong> Standard lexicon vocabulary nodes must be seeded as anchor points in Neo4j before semantic relationships can be created. If triggered now, Neo4j would contain orphaned relationships or fail integrity constraints.</span>
                                </div>
                            }
                            else if (importerStatus.Status == "Downloading")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Downloading assertions dataset (@(importerStatus.Progress.ToString("0.0"))%)</span>
                                    <span>@(FormatBytes(importerStatus.DownloadedBytes)) / @(FormatBytes(importerStatus.TotalBytes))</span>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(importerStatus.Progress)%;" aria-valuenow="@(importerStatus.Progress)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                            else if (importerStatus.Status == "Importing")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Parsing & Bulk-Inserting to Neo4j</span>
                                    <strong>@(importerStatus.ImportedEdges.ToString("N0")) edges</strong>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted d-block mt-1">Processed lines: @(importerStatus.ProcessedLines.ToString("N0"))</small>
                            }
                            else if (importerStatus.Status == "Completed")
                            {
                                <div class="alert alert-success py-2 mb-0"><i class="bi bi-check-circle-fill"></i> Seeding completed successfully. Total imported edges: <strong>@(importerStatus.ImportedEdges.ToString("N0"))</strong></div>
                            }
                            else if (importerStatus.Status == "Failed")
                            {
                                <div class="alert alert-danger py-2 mb-0"><i class="bi bi-exclamation-octagon-fill"></i> Seeding failed: @(importerStatus.ErrorMessage)</div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">ConceptNet knowledge base is currently idle. Click trigger to begin seeding.</p>
                            }
                        </div>
                        <div class="col-md-3 text-end">
                            @if (seederStatus == null || seederStatus.Status != "Completed")
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-lock-fill"></i> Blocked (No Lexicon)</button>
                            }
                            else if (importerStatus.Status == "Idle" || importerStatus.Status == "Completed" || importerStatus.Status == "Failed")
                            {
                                <button class="btn btn-primary w-100 mb-2" @onclick="TriggerImport"><i class="bi bi-play-fill"></i> Trigger Import</button>
                                <button class="btn btn-outline-danger w-100" @onclick="ResetConceptNet"><i class="bi bi-trash-fill"></i> Reset ConceptNet Data</button>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-hourglass-split"></i> Importing...</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ==================== STEP 4: GRAMMAR & INFLECTION PIPELINE ==================== -->
    <div class="border border-success rounded p-4 mb-4 bg-light bg-opacity-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="text-success mb-0"><span class="badge bg-success me-2">Step 4</span> Grammar &amp; Inflection Pipeline (Syntactic Model Training)</h3>
            @{
                var step4Status = GetStepStatusLabel(4);
                string badgeClass4 = step4Status == "Completed" ? "bg-success" : step4Status == "Running" ? "bg-primary" : step4Status == "Blocked" ? "bg-secondary" : "bg-info";
            }
            <span class="badge @badgeClass4">@step4Status</span>
        </div>
        <p class="text-muted small">
            <strong>What this action will do:</strong> This step runs in three sequential phases: (1) Ingest dependency treebanks to merge syntax trees onto the Neo4j graph nodes; (2) Mine grammatical rules and morphological inflection trigger patterns via Cypher queries; and (3) Train an ML.NET classification model to tag POS, syntax trees, and inflection structures at runtime.
        </p>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><i class="bi bi-book-half"></i> Grammar &amp; Inflection Pipeline</div>
            <div class="card-body">
                @if (grammarStatus == null)
                {
                    <div class="d-flex align-items-center text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                        <span>Loading Grammar Pipeline status...</span>
                    </div>
                }
                else
                {
                    <div class="row align-items-center">
                        <div class="col-md-3 mb-3 mb-md-0">
                            <div class="p-3 border rounded text-center">
                                <span class="text-muted d-block small mb-1">Pipeline Status</span>
                                @if (grammarStatus.Status == "Idle")
                                {
                                    <span class="badge bg-secondary fs-6"><i class="bi bi-info-circle"></i> Idle</span>
                                }
                                else if (grammarStatus.Status == "Ingesting")
                                {
                                    <span class="badge bg-warning text-dark fs-6"><i class="bi bi-download"></i> Ingesting Treebank</span>
                                }
                                else if (grammarStatus.Status == "Mining")
                                {
                                    <span class="badge bg-primary fs-6"><i class="bi bi-arrow-repeat spin"></i> Mining Rules</span>
                                }
                                else if (grammarStatus.Status == "Training")
                                {
                                    <span class="badge bg-info text-dark fs-6"><i class="bi bi-cpu-fill spin"></i> Training Tagger</span>
                                }
                                else if (grammarStatus.Status == "Completed")
                                {
                                    <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Completed</span>
                                }
                                else if (grammarStatus.Status == "Failed")
                                {
                                    <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle"></i> Failed</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3 mb-md-0">
                            @if (seederStatus == null || seederStatus.Status != "Completed")
                            {
                                <div class="alert alert-warning py-2 mb-0 small">
                                    <h6 class="alert-heading fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill"></i> Step 4 Blocked: Waiting for Step 2 (Lexicon Graph Seeding)</h6>
                                    <span><strong>Reason:</strong> Syntactic structures, treebank annotations, and mined rules require target vocabulary nodes (created in Step 2) inside the Neo4j Graph Database. The tagger cannot train on non-existent lexical anchors.</span>
                                </div>
                            }
                            else if (grammarStatus.Status == "Ingesting")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Ingesting Dependency Treebank (@(grammarStatus.Progress.ToString("0.0"))%)</span>
                                    <span>@(grammarStatus.ProcessedItems.ToString("N0")) / @(grammarStatus.TotalItems.ToString("N0"))</span>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(grammarStatus.Progress)%;" aria-valuenow="@(grammarStatus.Progress)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted d-block mt-1">Nodes merged: @(grammarStatus.MergedNodes.ToString("N0")) | Relationships merged: @(grammarStatus.MergedEdges.ToString("N0"))</small>
                            }
                            else if (grammarStatus.Status == "Mining")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Mining Grammatical Rules Trigger Patterns</span>
                                    <strong>Mining...</strong>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                            else if (grammarStatus.Status == "Training")
                            {
                                <div class="mb-1 d-flex justify-content-between small">
                                    <span>Training ML.NET Sequence Classifier (@(grammarStatus.Progress.ToString("0.0"))%)</span>
                                    <span>Evaluating accuracy...</span>
                                </div>
                                <div class="progress" style="height: 15px;">
                                    <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(grammarStatus.Progress)%;" aria-valuenow="@(grammarStatus.Progress)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                            else if (grammarStatus.Status == "Completed")
                            {
                                <div class="alert alert-success py-2 mb-0">
                                    <i class="bi bi-check-circle-fill"></i> Operation completed successfully. 
                                    @if (grammarStatus.ModelAccuracy > 0)
                                    {
                                        <span>Model Accuracy: <strong>@( (grammarStatus.ModelAccuracy * 100).ToString("0.00") )%</strong></span>
                                    }
                                </div>
                            }
                            else if (grammarStatus.Status == "Failed")
                            {
                                <div class="alert alert-danger py-2 mb-0"><i class="bi bi-exclamation-octagon-fill"></i> Pipeline failed: @(grammarStatus.ErrorMessage)</div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Grammar pipeline is currently idle. Select an action below to begin.</p>
                            }
                            
                            @if (grammarStatus.Logs != null && grammarStatus.Logs.Length > 0)
                            {
                                <div class="mt-2 p-2 border rounded" style="max-height: 120px; overflow-y: auto; font-family: monospace; font-size: 0.8rem;">
                                    @foreach (var log in grammarStatus.Logs)
                                    {
                                        <div class="text-truncate">@log</div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="col-md-3 text-end">
                            @if (seederStatus == null || seederStatus.Status != "Completed")
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-lock-fill"></i> Blocked (No Lexicon)</button>
                            }
                            else if (grammarStatus.Status == "Idle" || grammarStatus.Status == "Completed" || grammarStatus.Status == "Failed")
                            {
                                <button class="btn btn-outline-primary w-100 mb-2 btn-sm" @onclick="TriggerGrammarIngest"><i class="bi bi-play-fill"></i> 1. Ingest Treebank</button>
                                <button class="btn btn-outline-primary w-100 mb-2 btn-sm" @onclick="TriggerGrammarMine"><i class="bi bi-magic"></i> 2. Mine Rules</button>
                                <button class="btn btn-outline-primary w-100 mb-2 btn-sm" @onclick="TriggerGrammarTrain"><i class="bi bi-cpu"></i> 3. Train Classifier</button>
                                <button class="btn btn-outline-danger w-100 btn-sm" @onclick="ResetGrammar"><i class="bi bi-trash-fill"></i> Reset Grammar Data</button>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled><i class="bi bi-hourglass-split"></i> Running...</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


